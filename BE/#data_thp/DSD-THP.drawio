        <mxCell id="Rl2wLRBMNRgKhnNEsvzI-7" value="&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-- ====================&lt;/span&gt;&lt;/div&gt;&lt;div&gt;-- Komponen Penghasilan &amp;amp; Potongan&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE komponen_penghasilan (&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_code VARCHAR(10) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_nm VARCHAR(100),&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;default_nilai INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;default_satuan VARCHAR(20),&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;entried_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;event_id&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES kegiatan(event_id),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;entried_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE komponen_potongan (&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_code VARCHAR(10) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_nm VARCHAR(100),&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;default_nilai INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;default_satuan VARCHAR(20),&lt;/div&gt;&lt;div&gt;&amp;nbsp; presensi_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;entried_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;presensi_id&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES&amp;nbsp;&lt;/span&gt;presensi&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;(&lt;/span&gt;presensi&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;_id),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;entried_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;-- Input Penghasilan &amp;amp; Potongan Pegawai&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE penghasilan_pegawai (&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_peg_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; periode DATE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nilai DECIMAL(12,2) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; satuan VARCHAR(20) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; FOREIGN KEY (nik) REFERENCES pegawai(nik),&lt;/div&gt;&lt;div&gt;&amp;nbsp; FOREIGN KEY (penghasilan_id) REFERENCES komponen_penghasilan(penghasilan_id)&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE potongan_pegawai (&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_peg_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; periode DATE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nilai DECIMAL(12,2) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; satuan VARCHAR(20) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; FOREIGN KEY (nik) REFERENCES pegawai(nik),&lt;/div&gt;&lt;div&gt;&amp;nbsp; FOREIGN KEY (potongan_id) REFERENCES komponen_potongan(potongan_id)&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;-- THP (Take Home Pay)&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE pembayaran_pegawai (&lt;/div&gt;&lt;div&gt;&amp;nbsp; payment_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; periode DATE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; penghasilan_peg_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; potongan_peg_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; total_penghasilan DECIMAL(12,2),&lt;/div&gt;&lt;div&gt;&amp;nbsp; total_potongan DECIMAL(12,2),&lt;/div&gt;&lt;div&gt;&amp;nbsp; thp DECIMAL(12,2),&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;-- User Login&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE users (&lt;/div&gt;&lt;div&gt;&amp;nbsp; user_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; username VARCHAR(50) UNIQUE NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; password VARCHAR(255) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; role ENUM(&#39;admin&#39;, &#39;pegawai&#39;, &#39;kepegawaian&#39;, &#39;pejabat_teknis&#39;, &#39;keuangan&#39;) DEFAULT &#39;pegawai&#39;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; pegawai_id INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; FOREIGN KEY (nik) REFERENCES pegawai(nik)&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-- =====================&lt;/div&gt;&lt;div&gt;-- Setting &amp;amp; Filtering&lt;/div&gt;&lt;div&gt;-- =====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE INDEX idx_nik ON penghasilan_pegawai(nik);&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;verticalAlign=top;perimeterSpacing=0;spacingLeft=10;spacingRight=10;" parent="Rl2wLRBMNRgKhnNEsvzI-4" vertex="1">

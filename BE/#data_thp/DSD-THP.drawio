        <mxCell id="Rl2wLRBMNRgKhnNEsvzI-5" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-- ====================&lt;/span&gt;&lt;/div&gt;&lt;div&gt;-- Tabel Referensi, Pegawai dan Mutasi&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE pegawai (&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16) PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; employee_nm VARCHAR(100) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; birth_dt DATE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; place_of_birth VARCHAR(100),&lt;/div&gt;&lt;div&gt;&amp;nbsp; nip VARCHAR(18) UNIQUE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; pangkat VARCHAR(50),&lt;/div&gt;&lt;div&gt;&amp;nbsp; golongan VARCHAR(5),&lt;/div&gt;&lt;div&gt;&amp;nbsp; mkg INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; npwp VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; education VARCHAR(50),&lt;/div&gt;&lt;div&gt;&amp;nbsp; employee_sts ENUM(&#39;pns&#39;, &#39;pppk&#39;, &#39;honorer&#39;, &#39;blud&#39;, &#39;mou&#39;) DEFAULT &#39;blud&#39;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; doctor_sts ENUM(&#39;Bedah&#39;,&#39;Non Bedah&#39;)&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;DEFAULT &#39;Non Bedah&#39;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;verified_by VARCHAR(16),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;CREATE TABLE rekening (&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; rek_number VARCHAR(16) PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; bank_name VARCHAR(100) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; bank_code VARCHAR(3) NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;FOREIGN KEY (nik) REFERENCES pegawai(nik),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CREATE TABLE mutasi_pegawai (&lt;/div&gt;&lt;div&gt;&amp;nbsp; mutation_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; mutation_dt DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; jabatan VARCHAR(50),&lt;/div&gt;&lt;div&gt;&amp;nbsp; unit_id_from VARCHAR(20),&lt;/div&gt;&lt;div&gt;&amp;nbsp; unit_id_to VARCHAR(20),&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;verified_by VARCHAR(16),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;nik&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-- ====================&lt;/span&gt;&lt;/div&gt;&lt;div&gt;-- Kegiatan Pegawai&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE kegiatan (&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_dt DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; location_nm VARCHAR(100),&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;verified_by VARCHAR(16),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE daftar_hadir (&lt;/div&gt;&lt;div&gt;&amp;nbsp; daftar_hadir_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_id INT,&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;verified_by VARCHAR(16),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;event_id&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES kegiatan(event_id),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-- ====================&lt;/span&gt;&lt;/div&gt;&lt;div&gt;-- Presensi Pegawai&lt;/div&gt;&lt;div&gt;-- ====================&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;CREATE TABLE presensi (&lt;/div&gt;&lt;div&gt;&amp;nbsp; presensi_id INT AUTO_INCREMENT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; presensi_month DATE NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; prosentase_alpha INT NOT NULL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; nik VARCHAR(16),&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;verified_by VARCHAR(16),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_by VARCHAR(16),&lt;/div&gt;&lt;div&gt;&amp;nbsp; verified_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp; validated_at DATETIME,&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;nik&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik),&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;verified_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;FOREIGN KEY (&lt;/span&gt;validated_by&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;) REFERENCES pegawai(nik)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ON DELETE SET NULL&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;verticalAlign=top;perimeterSpacing=0;spacingLeft=10;spacingRight=10;" parent="Rl2wLRBMNRgKhnNEsvzI-4" vertex="1">
